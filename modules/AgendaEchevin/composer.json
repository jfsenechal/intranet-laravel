{
    "name": "acmarche/agenda-echevin",
    "description": "Agenda Echevin management module for AcMarche",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "AcMarche",
            "email": "info@acmarche.be"
        }
    ],
    "require": {
        "php": "^8.5",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^12.0|^13.0",
        "spatie/laravel-sluggable": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "AcMarche\\AgendaEchevin\\": "src/",
            "AcMarche\\AgendaEchevin\\Database\\Factories\\": "database/factories/",
            "AcMarche\\AgendaEchevin\\Database\\Seeders\\": "database/seeders/",
            "AcMarche\\AgendaEchevin\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AcMarche\\AgendaEchevin\\Providers\\AgendaEchevinServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
