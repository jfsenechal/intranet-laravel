{
    "name": "acmarche/college",
    "description": "College (Collège communal) module for AcMarche intranet",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "AcMarche",
            "email": "info@acmarche.be"
        }
    ],
    "require": {
        "php": "^8.5",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "AcMarche\\College\\": "src/",
            "AcMarche\\College\\Database\\Factories\\": "database/factories/",
            "AcMarche\\College\\Database\\Seeders\\": "database/seeders/",
            "AcMarche\\College\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AcMarche\\College\\Providers\\CollegeServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
